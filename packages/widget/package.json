{
  "name": "@hanzo/waitlist",
  "version": "0.1.0",
  "description": "Monochromatic, brand-neutral viral waitlist widget. Backed by Hanzo Base.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/waitlist.iife.js",
    "*.css"
  ],
  "main": "./dist/waitlist.cjs",
  "module": "./dist/waitlist.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/waitlist.js",
      "require": "./dist/waitlist.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./element": "./dist/waitlist.iife.js",
    "./styles.css": "./dist/waitlist.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build -c vite.element.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": false },
    "react-dom": { "optional": false }
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "terser": "^5.48.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0"
  }
}
